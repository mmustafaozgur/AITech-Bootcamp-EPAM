# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/auth_db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Password Reset
RESET_TOKEN_EXPIRES_MINUTES=60

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password

# Frontend URL (used in reset-password email link)
FRONTEND_URL=http://localhost:5173
